# ============================================
# DONNÉES LOURDES (ne pas uploader sur GitHub)
# ============================================

# Images (garder le dossier via .gitkeep, ignorer le contenu)
data/raw/images/*
!data/raw/images/.gitkeep

# Textes (garder le dossier via .gitkeep, ignorer le contenu)
data/raw/texts/*
!data/raw/texts/.gitkeep

# Fichiers CSV (Raw, Processed et DataWarehouse)
data/raw/tabular/*.csv
data/processed/*.csv
data/processed/*checkpoint*.csv
DataWarehouse/postgres/*.csv

# ============================================
# ENVIRONNEMENT VIRTUEL & SECRETS
# ============================================
myenv/
venv/
env/
.env

# ============================================
# PYTHON & IDE
# ============================================
__pycache__/
*.py[cod]
*$py.class
.Python
.vscode/
.idea/

# ============================================
# JUPYTER & OS
# ============================================
.ipynb_checkpoints/
*.log
.DS_Store
Thumbs.db
